{
  "name": "@cerner/carbon-graphs",
  "main": "lib/Graphs.js",
  "version": "2.23.1",
  "description": "A graphing library built using d3 based on Cerner design standards",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cerner/terra-graphs.git",
    "directory": "packages/carbon-graphs"
  },
  "keywords": [
    "Cerner",
    "Terra",
    "carbon-graphs",
    "carbon",
    "graphs",
    "UI",
    "d3",
    "d3-module",
    "graphing"
  ],
  "author": "Cerner Corporation",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/cerner/terra-graphs/issues"
  },
  "homepage": "https://github.com/cerner/terra-graphs#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "d3-array": "1",
    "d3-axis": "1",
    "d3-drag": "1",
    "d3-ease": "1",
    "d3-format": "1",
    "d3-geo": "1",
    "d3-hierarchy": "1",
    "d3-interpolate": "1",
    "d3-path": "1",
    "d3-scale": "2",
    "d3-selection": "1",
    "d3-shape": "1",
    "d3-time": "1",
    "d3-time-format": "2",
    "d3-timer": "1",
    "d3-transition": "1",
    "uuid": "3.4.0"
  },
  "devDependencies": {
    "@cerner/carbon-site-helpers": "^1.11.3",
    "@cerner/svg-to-carbon": "^1.1.3",
    "express": "^4.17.1",
    "express-rate-limit": "^5.1.3",
    "karma": "^5.1.0",
    "karma-chrome-launcher": "^3.1.0",
    "karma-coverage": "^2.0.2",
    "karma-jasmine": "^3.3.1",
    "karma-parallel": "^0.3.1",
    "karma-sourcemap-loader": "^0.3.7",
    "karma-webpack": "^4.0.2",
    "less": "^3.12.2",
    "less-loader": "^7.0.2",
    "puppeteer": "^5.3.1",
    "sinon": "^9.2.0"
  },
  "scripts": {
    "clean": "npm run clean:node_modules && npm run clean:lib",
    "clean:install": "npm run clean && time npm install",
    "clean:lib": "rm -rf lib",
    "clean:node_modules": "echo 'removing ./node_modules' && rm -rf node_modules && echo 'removed ./node_modules'",
    "compile": "babel --root-mode upward src --out-dir lib --copy-files",
    "lint": "npm run lint:js && npm run lint:scss",
    "lint:js": "eslint --ext .js . --ignore-path ../../.eslintignore",
    "lint:js:fix": "eslint--ext .js,.jsx . --ignore-path ../../.eslintignore --fix ",
    "lint:scss": "stylelint src/**/*.scss",
    "precompile": "rm -rf lib",
    "test": "npm run lint && npm run karma",
    "karma": "karma start karma.config.js --single-run --no-auto-watch"
  }
}
